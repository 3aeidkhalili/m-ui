# کپی کنید به backend/.env و مقادیر را تنظیم کنید

# ---------- پنل ----------
PANEL_DOMAIN=vpn.example.com
SERVER_PUBLIC_IP=203.0.113.10        # IP عمومی سرور (برای کانفیگ کلاینت‌ها)
API_HOST=127.0.0.1
API_PORT=8443
# اجباری: کلید تصادفی حداقل ۳۲ کاراکتری. با این تولید کنید:  openssl rand -hex 32
# اگر خالی/ضعیف بماند، بک‌اند در حالت production بوت نمی‌شود (fail-closed).
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=                        # خالی = same-origin (بدون CORS باز)
# پشت پروکسیِ مورد اعتماد (nginx) true؛ در دسترسی مستقیم false. اگر true اشتباه باشد،
# مهاجم می‌تواند با X-Forwarded-For جعلی قفل لاگین/rate-limit را دور بزند.
TRUSTED_PROXY=false

# ادمین اولیه (فقط برای app.seed) — خالی بگذارید تا یک رمز تصادفی ساخته و چاپ شود
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---------- دیتابیس ----------
DATABASE_URL=sqlite:///./multivpn.db

# ---------- Xray ----------
XRAY_BIN=/usr/local/bin/xray
XRAY_CONFIG=/usr/local/etc/xray/config.json
XRAY_API_ADDR=127.0.0.1:10085
TPROXY_PORT=12345
TRAFFIC_JOB_INTERVAL=30

# ---------- ساب‌نت‌های داخلی هر پروتکل ----------
OVPN_SUBNET=10.8.0.0/24
WG_SUBNET=10.9.0.0/24
L2TP_SUBNET=10.10.0.0/24
# ایندکس کاربر از این عدد شروع می‌شود (2..254 ؛ 1 معمولاً برای سرور رزرو است)
USER_INDEX_START=11

# ---------- WireGuard ----------
WG_INTERFACE=wg0
WG_LISTEN_PORT=51820
WG_SERVER_PRIVATE_KEY=          # install.sh پر می‌کند
WG_SERVER_PUBLIC_KEY=

# ---------- OpenVPN ----------
OVPN_PORT=2096
OVPN_PROTO=udp
EASYRSA_DIR=/etc/openvpn/easy-rsa
OVPN_CCD_DIR=/etc/openvpn/ccd
OVPN_TLS_CRYPT=/etc/openvpn/tls-crypt.key

# ---------- L2TP ----------
L2TP_PSK=                        # install.sh یک مقدار تصادفی می‌گذارد
L2TP_CHAP_SECRETS=/etc/ppp/chap-secrets

# ---------- مسیر اسکریپت‌های provisioning ----------
SCRIPTS_DIR=/opt/multivpn/scripts
PROVISIONING_ENABLED=true        # روی ویندوز/لوکال false کنید
